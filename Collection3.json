  "item": [
    {
      "name": "creer brand",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Verifier le code status\", function(){\r",
              "    let code_attendu = 201;\r",
              "    let code_obtenu = pm.response.code;\r",
              "    //assertions\r",
              "    pm.expect(code_attendu).equal(code_obtenu);\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Verifier les donnees envoyees avec la reponse\", function(){\r",
              "    // Recuperer ce que j'ai envoye (body request)\r",
              "    let body_req = JSON.parse(pm.request.body.raw)\r",
              "    let name_req = body_req.name\r",
              "    let slug_req = body_req.slug\r",
              "\r",
              "    // Recuperer body response\r",
              "    let body_res = pm.response.json()\r",
              "    let name_res = body_res.name\r",
              "    let slug_res = body_res.slug\r",
              "\r",
              "    //Faire les assertions (verification)\r",
              "    pm.expect(name_req).equal(name_res)\r",
              "    pm.expect(slug_req).equal(slug_res)\r",
              "\r",
              "    //Variable de collection\r",
              "    let id_res = body_res.id;\r",
              "    pm.collectionVariables.set(\"id_objet\", id_res)\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
